<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Added the constraints for entity Swap.
    -->
    <changeSet id="20260309163303-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="outgoing_item_id"
                                 baseTableName="swap"
                                 constraintName="fk_swap__outgoing_item_id"
                                 referencedColumnNames="id"
                                 referencedTableName="stock_item"/>

        <addForeignKeyConstraint baseColumnNames="incoming_item_id"
                                 baseTableName="swap"
                                 constraintName="fk_swap__incoming_item_id"
                                 referencedColumnNames="id"
                                 referencedTableName="stock_item"/>
    </changeSet>
</databaseChangeLog>
